# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
worktrees/
queue/

# Results — track summaries and key visuals, not raw logs
results/*.tsv
results/logs_*/
results/sweep_5min/
results/mps_pretest/*.log

# Viz — generated PNGs (regenerate from scripts)
viz/

# Agent prompt files (generated per-session by launchers)
CLAUDE.md
AGENTS.md

# Experimental code/artifacts
dev/

# Native build output (rebuild on target machine)
native/build/

# CoreML model artifacts
*.mlpackage
*.mlmodelc

# Checkpoint files
*.pt
*.bin
.worktrees
